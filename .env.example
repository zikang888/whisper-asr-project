# Environment Configuration
# This file contains all configuration settings for the Whisper ASR training project

# ====================
# Hugging Face Settings
# ====================
# Hugging Face cache directory (where downloaded data/models will be stored)
HF_HOME="./hf_cache"

# Hugging Face mirror (faster download in China, comment out if not needed)
HF_ENDPOINT="https://hf-mirror.com"

# ====================
# Project Paths
# ====================
# Project root directory (current directory by default)
PROJECT_ROOT="."

# Output directory for training results
OUTPUT_DIR="./output"

# ====================
# Model Configuration
# ====================
# Pre-trained Whisper model to download and fine-tune
MODEL_NAME="openai/whisper-small"

# Local directory for model (will be downloaded here)
MODEL_LOCAL_DIR="./models/whisper-small"

# ====================
# Dataset Configuration
# ====================
# LibriSpeech dataset settings
DATASET_NAME="librispeech_asr"
DATASET_CONFIG="clean"

# Training splits to use
TRAIN_SPLITS="train.100+train.360"
VALIDATION_SPLIT="validation"
TEST_SPLIT="test"

# ====================
# Quick Test Mode (For verification)
# ====================
# Set to True to use a small subset for quick testing
QUICK_TEST_MODE=true

# Number of samples for quick test (validation)
QUICK_TEST_SAMPLES=1000

# Number of validation samples in quick test
QUICK_TEST_VALIDATION=100

# ====================
# Training Parameters
# ====================
# Maximum training steps
MAX_TRAIN_STEPS=500

# Validation frequency (steps)
EVAL_STEPS=250

# Checkpoint saving frequency (steps)
SAVE_STEPS=500

# Batch sizes
PER_DEVICE_TRAIN_BATCH_SIZE=8
PER_DEVICE_EVAL_BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=4

# Learning rate
LEARNING_RATE=1e-4
WARMUP_STEPS=50

# ====================
# Data Loading Optimization
# ====================
# Number of workers for data loading (critical for GPU utilization)
# Recommend 4-8 if you have enough CPU cores
NUM_WORKERS=4

# Pin memory for faster GPU transfer
PIN_MEMORY=true

# ====================
# Mixed Precision Training
# ====================
# Use FP16 (faster training, less memory)
FP16_ENABLED=true

# ====================
# Evaluation Metrics
# ====================
# Calculate WER (Word Error Rate) and CER (Character Error Rate)
COMPUTE_WER=true
COMPUTE_CER=true

# ====================
# Output Settings
# ====================
# Generate training report
GENERATE_REPORT=true

# Save model checkpoint
SAVE_CHECKPOINT=true

# Keep only the best checkpoint
SAVE_ONLY_BEST=false
